      "parameters": {
        "jsCode": "const novaLinha = $('Parse + Valida4').item.json.csvLine;\nlet existente = 'data,descricao,valor,categoria,forma_pagamento,tipo\\n';\ntry {\n  const binaryData = await this.helpers.getBinaryDataBuffer(0, 'data');\n  if (binaryData) {\n    let raw = binaryData.toString('utf8').replace(/^[^a-zA-Z0-9\"'\\n\\r]+/g, '').trim();\n    if (raw !== '') { \n      existente = raw + '\\n'; \n    }\n  }\n} catch (e) {}\nconst conteudoFinal = existente + novaLinha;\nreturn [{ json: { chatId: $('Parse + Valida4').item.json.chatId, mensagem: $('Parse + Valida4').item.json.mensagem }, binary: { data: { data: Buffer.from(conteudoFinal, 'utf8').toString('base64'), mimeType: 'text/csv', fileName: 'gastos.csv' } } }];"
