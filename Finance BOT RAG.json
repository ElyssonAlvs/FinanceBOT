    {
      "parameters": {
        "jsCode": "const chatId = $('Telegram Trigger4').item.json.message.chat.id;\nlet dados = [];\n\ntry {\n  const binaryData = await this.helpers.getBinaryDataBuffer(0, 'data');\n  if (binaryData) {\n    const content = binaryData.toString('utf8');\n    const lines = content.split(/\\r?\\n/).filter(l => l.trim() !== '');\n    if (lines.length > 1) {\n      const headers = lines[0].split(',').map(h => h.trim());\n      dados = lines.slice(1).map(line => {\n        const values = line.split(',');\n        const obj = {};\n        headers.forEach((h, i) => obj[h] = (values[i] || '').trim());\n        return { json: obj };\n      });\n    }\n  }\n} catch (e) {}\n\nif (dados.length === 0) {\n  return [{ json: { chatId, mensagem: '📭 Nenhum dado para resumo.' } }];\n}\n\nconst totais = {};\nconst porMes = {};\nconst agora = new Date();\nconst offsetBrasilia = -3 * 60;\nconst localMs = agora.getTime() + (agora.getTimezoneOffset() + offsetBrasilia) * 60000;\nconst local = new Date(localMs);\nconst mesAtual = `${local.getFullYear()}-${String(local.getMonth() + 1).padStart(2, '0')}`;\n\ndados.forEach(item => {\n  const d = item.json;\n  const valor = parseFloat(d.valor || 0);\n  const cat = d.categoria || 'outros';\n  const tipo = (d.tipo || 'despesa').trim().toLowerCase();\n  const mes = (d.data || '').slice(0, 7);\n  if (tipo !== 'receita') {\n    totais[cat] = (totais[cat] || 0) + valor;\n    porMes[mes] = (porMes[mes] || 0) + valor;\n  }\n});\n\nconst totalGeral = Object.values(totais).reduce((a, b) => a + b, 0);\nconst emojis = { alimentacao: '🍽️', transporte: '🚗', moradia: '🏠', saude: '💊', lazer: '🎉', educacao: '📚', compras: '🛒', assinaturas: '📱', contas: '📄', outros: '📌' };\n\nconst cats = Object.entries(totais)\n  .sort((a, b) => b[1] - a[1])\n  .map(([cat, val]) => {\n    const ic = emojis[cat] || '💰';\n    return `${ic} *${cat}:* R$ ${val.toFixed(2)} (${((val / totalGeral) * 100).toFixed(0)}%)`;\n  })\n  .join('\\n');\n\nreturn [{\n  json: {\n    chatId,\n    mensagem: `📊 *Resumo Financeiro*\\n\\n${cats}\\n\\n💵 *Total geral: R$ ${totalGeral.toFixed(2)}*\\n📅 *Este mês (${mesAtual}): R$ ${(porMes[mesAtual] || 0).toFixed(2)}*\\n📝 ${dados.length} registros`\n  }\n}];"
      },
