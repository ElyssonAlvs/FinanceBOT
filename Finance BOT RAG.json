      "parameters": {
        "jsCode": "const ragData = $(\"RAG_HTTP_Search\").first().json;\nconst analytics = $(\"RAG_HTTP_Analytics\").first().json;\nconst pergunta = $(\"RAG_Extrai_Pergunta\").first().json.pergunta;\nconst chatId = $(\"RAG_Extrai_Pergunta\").first().json.chatId;\n\nconst resultados = (ragData.results || []).map((r, i) => {\n  const d = r.metadata || r;\n  return `[${i+1}] ${d.data || ''} | ${d.descricao || ''} | R$ ${parseFloat(d.valor || 0).toFixed(2)} | ${d.categoria || ''} | ${d.forma_pagamento || '-'} | score: ${(r.score_normalized || 0).toFixed(2)}`;\n}).join('\\n');\n\n// Pega os itens recentes do analytics para evitar alucinação sobre o 'último'\nconst recentes = (analytics.recent_items || []).map(d => \n  `- ${d.data}: ${d.descricao} (R$ ${parseFloat(d.valor).toFixed(2)})`\n).join('\\n');\n\nconst analiticsTexto = JSON.stringify(analytics, null, 2);\n\nconst prompt = `Você é um robô de análise financeira que SÓ lê os dados abaixo. Proibido usar memória externa.\\n\\nPergunta: \"${pergunta}\"\\n\\nDADOS REAIS DO CSV (SÓ USE ESTES):\\n${resultados || 'Vazio'}\\n\\nREGISTROS MAIS RECENTES:\\n${recentes || 'Vazio'}\\n\\nRESUMO CONSOLIDADO:\\n${analiticsTexto}\\n\\nINSTRUÇÃO ABSOLUTA:\\n- Se a pergunta for sobre o \"último\" ou \"mais recente\", use a lista de REGISTROS MAIS RECENTES.\\n- Responda de forma curta e amigável em português.`;\n\nreturn [{ json: { prompt, chatId } }];"
      },
