      ],
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "const novaLinha = $('Parse + Valida').item.json.csvLine;\nlet existente = 'data,descricao,valor,categoria,forma_pagamento,tipo\\n';\n\nconst dados = $('Extract (registrar)').all();\nif (dados.length > 0 && dados[0].json.data) {\n  existente = 'data,descricao,valor,categoria,forma_pagamento,tipo\\n' + \n    dados.map(d => [\n      d.json.data,\n      d.json.descricao,\n      d.json.valor,\n      d.json.categoria,\n      d.json.forma_pagamento || '',\n      d.json.tipo || 'despesa'\n    ].join(',')).join('\\n') + '\\n';\n}\n\nconst conteudoFinal = existente + novaLinha;\n\nreturn [\n  {\n    json: {\n      chatId: $('Parse + Valida').item.json.chatId,\n      mensagem: $('Parse + Valida').item.json.mensagem,\n    },\n    binary: {\n      data: {\n        data: Buffer.from(conteudoFinal, 'utf8').toString('base64'),\n        mimeType: 'text/csv',\n        fileName: 'gastos.csv',\n      },\n    },\n  },\n];"
      },
