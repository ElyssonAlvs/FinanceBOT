    {
      "parameters": {
        "jsCode": "// FIX: Calcula data no horário de Brasília (UTC-3) dentro do Code node\nconst agora = new Date();\nconst offsetBrasilia = -3 * 60; // minutos\nconst localMs = agora.getTime() + (agora.getTimezoneOffset() + offsetBrasilia) * 60000;\nconst local = new Date(localMs);\n\nconst ano = local.getFullYear();\nconst mes = String(local.getMonth() + 1).padStart(2, '0');\nconst dia = String(local.getDate()).padStart(2, '0');\nconst dataBrasilia = `${ano}-${mes}-${dia}`;\n\nreturn [{ json: { dataBrasilia } }];"
      },
      "id": "8e29875c-55c4-4811-ae0b-60289ce95543",
      "name": "Data Brasilia",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        5216,
        8480
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Você é um extrator financeiro. Leia a mensagem abaixo e retorne SOMENTE um JSON válido, sem markdown, sem texto extra, sem explicações.\n\nRegras:\n- tipo: \"despesa\" (padrão) ou \"receita\"\n- valor: número decimal sem símbolo de moeda\n- categoria: uma de [alimentacao, transporte, moradia, saude, lazer, educacao, compras, assinaturas, contas, outros]\n- descricao: resumo curto em minúsculas\n- data: hoje se não informada, formato YYYY-MM-DD\n- forma_pagamento: pix, credito, debito, dinheiro, ou null se não informado\n\nData de hoje (horário de Brasília): {{ $('Data Brasilia').item.json.dataBrasilia }}\nMensagem: {{ $('Telegram Trigger').item.json.message.text }}\n\nJSON:",
        "options": {
          "systemMessage": "Você é um assistente de finanças pessoais. Retorne SEMPRE e SOMENTE JSON puro válido. Nunca adicione texto fora do JSON."
        }
      },
      "id": "4a3f877f-239a-4964-8a62-7e3ff1eaf776",
      "name": "AI Agent - Extrai JSON",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1.7,
      "position": [
        5440,
        8480
      ]
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.item.json.output;\n\nlet parsed;\ntry {\n  const clean = raw.replace(/```json\\n?/g, '').replace(/```/g, '').trim();\n  const match = clean.match(/\\{[\\s\\S]*\\}/);\n  if (!match) throw new Error('Sem JSON na resposta');\n  parsed = JSON.parse(match[0]);\n} catch(e) {\n  throw new Error('AI não retornou JSON válido: ' + raw);\n}\n\nif (!parsed.valor || isNaN(Number(parsed.valor))) {\n  throw new Error('Valor não identificado na mensagem');\n}\n\nif (!parsed.data) {\n  parsed.data = $('Data Brasilia').item.json.dataBrasilia;\n}\nif (!parsed.categoria) parsed.categoria = 'outros';\nif (!parsed.descricao) parsed.descricao = 'sem descricao';\n\nconst csvLine = [\n  parsed.data,\n  parsed.descricao.replace(/,/g, ' ').replace(/\\n/g, ' '),\n  Number(parsed.valor).toFixed(2),\n  parsed.categoria,\n  parsed.forma_pagamento || '',\n  parsed.tipo || 'despesa'\n].join(',') + '\\n';\n\nconst emojis = {\n  alimentacao: '🍽️', transporte: '🚗', moradia: '🏠',\n  saude: '💊', lazer: '🎉', educacao: '📚',\n  compras: '🛒', assinaturas: '📱', contas: '📄', outros: '📌'\n};\nconst ic = emojis[parsed.categoria] || '💰';\nconst fp = parsed.forma_pagamento ? `\\n💳 ${parsed.forma_pagamento}` : '';\n\nreturn [{\n  json: {\n    ...parsed,\n    csvLine,\n    chatId: $('Telegram Trigger').item.json.message.chat.id,\n    mensagem: `✅ *Registrado!*\\n\\n${ic} *${parsed.descricao}*\\n💰 R$ ${Number(parsed.valor).toFixed(2)}\\n📂 ${parsed.categoria} | 📅 ${parsed.data}${fp}`\n  }\n}];"
      },
      "id": "6bff84e8-ee07-42f0-b91b-02b145a2763a",
      "name": "Parse + Valida",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        5728,
        8480
      ]
    },
