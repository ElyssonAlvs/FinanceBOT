    {
      "parameters": {
        "jsCode": "const dados = $('Extract (ver)').all();\nconst chatId = $('Telegram Trigger').item.json.message.chat.id;\n\nif (dados.length === 0 || !dados[0].json.data) {\n  return [{ json: { chatId, mensagem: '📭 Nenhum gasto registrado ainda.' } }];\n}\n\nconst emojis = { alimentacao: '🍽️', transporte: '🚗', moradia: '🏠', saude: '💊', lazer: '🎉', educacao: '📚', compras: '🛒', assinaturas: '📱', contas: '📄', outros: '📌' };\n\nconst texto = dados\n  .slice(-10)\n  .reverse()\n  .map(item => {\n    const d = item.json;\n    const icone = emojis[d.categoria] || '💰';\n    return `${icone} *${d.descricao}* — R$ ${d.valor}\\n📅 ${d.data} | 📂 ${d.categoria}`;\n  })\n  .join('\\n\\n');\n\nreturn [{ json: { chatId, mensagem: `📋 *Últimos gastos:*\\n\\n${texto}\\n\\n_/resumo | /baixar_` } }];"
      },
