      "id": "53d69029-340b-4f01-91d2-c3cb1ff0bd3f",
      "name": "Ler CSV (resumo)",
      "type": "n8n-nodes-base.readWriteFile",
      "typeVersion": 1,
      "position": [
        5216,
        8256
      ],
      "alwaysOutputData": true,
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const dados = $('Extract (resumo)').all();\nconst chatId = $('Telegram Trigger').item.json.message.chat.id;\n\nif (dados.length === 0 || !dados[0].json.data) {\n  return [{ json: { chatId, mensagem: '📭 Nenhum dado para resumo.' } }];\n}\n\nconst totais = {};\nconst porMes = {};\nconst agora = new Date();\nconst offsetBrasilia = -3 * 60;\nconst localMs = agora.getTime() + (agora.getTimezoneOffset() + offsetBrasilia) * 60000;\nconst local = new Date(localMs);\nconst mesAtual = `${local.getFullYear()}-${String(local.getMonth() + 1).padStart(2, '0')}`;\n\ndados.forEach(item => {\n  const d = item.json;\n  const valor = parseFloat(d.valor) || 0;\n  const cat = d.categoria || 'outros';\n  const tipo = d.tipo ? d.tipo.trim() : 'despesa';\n  const mes = (d.data || '').slice(0, 7);\n  if (tipo !== 'receita') {\n    totais[cat] = (totais[cat] || 0) + valor;\n    porMes[mes] = (porMes[mes] || 0) + valor;\n  }\n});\n\nconst totalGeral = Object.values(totais).reduce((a, b) => a + b, 0);\nconst emojis = { alimentacao: '🍽️', transporte: '🚗', moradia: '🏠', saude: '💊', lazer: '🎉', educacao: '📚', compras: '🛒', assinaturas: '📱', contas: '📄', outros: '📌' };\n\nconst cats = Object.entries(totais)\n  .sort((a, b) => b[1] - a[1])\n  .map(([cat, val]) => `${emojis[cat] || '💰'} *${cat}:* R$ ${val.toFixed(2)} (${((val / totalGeral) * 100).toFixed(0)}%)`)\n  .join('\\n');\n\nreturn [{\n  json: {\n    chatId,\n    mensagem: `📊 *Resumo financeiro*\\n\\n${cats}\\n\\n💵 *Total geral: R$ ${totalGeral.toFixed(2)}*\\n📅 *Este mês (${mesAtual}): R$ ${(porMes[mesAtual] || 0).toFixed(2)}*\\n📝 ${dados.length} registros`\n  }\n}];"
      },
